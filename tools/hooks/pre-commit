#!/bin/bash
#
# Pre-commit hook for podcast episode publishing
#
# Drop audio files in episodes/inbox/, then commit. This hook will:
# 1. Normalize and center the audio
# 2. Upload to S3
# 3. Create episode metadata
# 4. Prevent audio files from being committed
#
# Requirements:
#   - ffmpeg (brew install ffmpeg)
#   - AWS CLI configured with S3 access
#   - jq (brew install jq)

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
INBOX_DIR="$REPO_ROOT/episodes/inbox"
EPISODES_DIR="$REPO_ROOT/episodes"
PROCESSED_DIR="$REPO_ROOT/episodes/processed"
NORMALIZE_SCRIPT="$REPO_ROOT/tools/normalize-audio.sh"

# S3 configuration - update these for your setup
S3_BUCKET="${PODCAST_S3_BUCKET:-your-bucket-name}"
S3_PREFIX="${PODCAST_S3_PREFIX:-podcast/episodes}"
CLOUDFRONT_URL="${PODCAST_CLOUDFRONT_URL:-https://your-cloudfront-url.com}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${BLUE}[pre-commit]${NC} $1"; }
success() { echo -e "${GREEN}[pre-commit]${NC} $1"; }
warn() { echo -e "${YELLOW}[pre-commit]${NC} $1"; }
error() { echo -e "${RED}[pre-commit]${NC} $1" >&2; }

# Check for required tools
check_dependencies() {
    local missing=()
    command -v ffmpeg &>/dev/null || missing+=("ffmpeg")
    command -v aws &>/dev/null || missing+=("aws-cli")
    command -v jq &>/dev/null || missing+=("jq")

    if [ ${#missing[@]} -gt 0 ]; then
        error "Missing required tools: ${missing[*]}"
        echo "Install with: brew install ${missing[*]}"
        exit 1
    fi
}

# Get audio duration in seconds
get_duration() {
    ffprobe -v error -show_entries format=duration -of csv=p=0 "$1" | cut -d. -f1
}

# Format duration as HH:MM:SS
format_duration() {
    local seconds=$1
    printf "%02d:%02d:%02d" $((seconds/3600)) $((seconds%3600/60)) $((seconds%60))
}

# Get next episode number
get_next_episode_number() {
    local max=0
    shopt -s nullglob
    local files=("$EPISODES_DIR"/*.json)
    shopt -u nullglob
    for f in "${files[@]}"; do
        [ -f "$f" ] || continue
        local num=$(jq -r '.episodeNumber // 0' "$f" 2>/dev/null)
        [ "$num" -gt "$max" ] && max=$num
    done
    echo $((max + 1))
}

# Process a single audio file
process_audio_file() {
    local input="$1"
    local filename=$(basename "$input")
    local basename="${filename%.*}"

    log "Processing: $filename"

    # Create temp directory for processing
    local tmpdir=$(mktemp -d)
    local normalized="$tmpdir/${basename}.mp3"

    # Normalize and center
    log "  Normalizing and centering audio..."
    "$NORMALIZE_SCRIPT" --center "$input" "$normalized" >/dev/null 2>&1

    # Get duration
    local duration_secs=$(get_duration "$normalized")
    local duration_formatted=$(format_duration "$duration_secs")

    # Generate S3 key and upload
    local episode_num=$(get_next_episode_number)
    local s3_key="${S3_PREFIX}/episode-${episode_num}.mp3"
    local s3_url="s3://${S3_BUCKET}/${s3_key}"
    local public_url="${CLOUDFRONT_URL}/${s3_key}"

    log "  Uploading to S3..."
    if ! aws s3 cp "$normalized" "$s3_url" \
        --content-type "audio/mpeg" \
        --cache-control "public, max-age=31536000" \
        --quiet; then
        error "  Failed to upload to S3. Check your AWS credentials."
        error "  Set PODCAST_S3_BUCKET, PODCAST_S3_PREFIX, PODCAST_CLOUDFRONT_URL environment variables."
        rm -rf "$tmpdir"
        return 1
    fi

    # Create metadata file
    local metadata_file="$EPISODES_DIR/episode-${episode_num}.json"
    local today=$(date +%Y-%m-%d)

    cat > "$metadata_file" << EOF
{
  "episodeNumber": ${episode_num},
  "season": 1,
  "title": "Episode ${episode_num}: [EDIT TITLE]",
  "description": "[EDIT DESCRIPTION]",
  "publishDate": "${today}",
  "duration": "${duration_formatted}",
  "durationSeconds": ${duration_secs},
  "audioUrl": "${public_url}",
  "explicit": false,
  "keywords": []
}
EOF

    success "  Created: $(basename "$metadata_file")"
    echo "  Audio URL: $public_url"
    echo "  Duration: $duration_formatted"

    # Stage the metadata file
    git add "$metadata_file"

    # Move original to processed folder
    mkdir -p "$PROCESSED_DIR"
    mv "$input" "$PROCESSED_DIR/"
    log "  Moved original to: episodes/processed/"

    # Cleanup
    rm -rf "$tmpdir"

    echo ""
    warn "  Remember to edit $metadata_file with the episode title and description!"
    echo ""
}

# Unstage any audio files that were accidentally staged
unstage_audio_files() {
    local staged_audio=$(git diff --cached --name-only | grep -E '\.(mp3|m4a|wav|flac|aac|ogg)$' || true)
    if [ -n "$staged_audio" ]; then
        log "Unstaging audio files (they should not be committed):"
        echo "$staged_audio" | while read -r file; do
            git reset HEAD "$file" 2>/dev/null || true
            warn "  Unstaged: $file"
        done
    fi
}

# Main
main() {
    # First, unstage any audio files that shouldn't be committed
    unstage_audio_files

    # Check for audio files in inbox
    shopt -s nullglob
    local audio_files=("$INBOX_DIR"/*.mp3 "$INBOX_DIR"/*.m4a "$INBOX_DIR"/*.wav "$INBOX_DIR"/*.flac)
    shopt -u nullglob

    if [ ${#audio_files[@]} -eq 0 ]; then
        # No audio files to process, continue with commit
        exit 0
    fi

    echo ""
    echo "========================================"
    echo "  New Podcast Episodes Detected!"
    echo "========================================"
    echo ""

    check_dependencies

    # Check S3 configuration
    if [ "$S3_BUCKET" = "your-bucket-name" ]; then
        error "S3 not configured. Set these environment variables:"
        echo "  export PODCAST_S3_BUCKET=your-bucket-name"
        echo "  export PODCAST_S3_PREFIX=podcast/episodes"
        echo "  export PODCAST_CLOUDFRONT_URL=https://your-cdn.com"
        echo ""
        echo "Or add them to your shell profile (~/.zshrc or ~/.bashrc)"
        exit 1
    fi

    # Process each audio file
    for audio_file in "${audio_files[@]}"; do
        [ -f "$audio_file" ] || continue
        process_audio_file "$audio_file"
    done

    success "All episodes processed!"
    echo ""
    echo "The commit will include the new episode metadata."
    echo "Audio files have been uploaded to S3 and moved to episodes/processed/"
    echo ""
}

main
